    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inv = $('Extraer Contacto').item.json;\nconst cardData = $('Obtener Tarjeta del Cliente').item.json;\nconst card = cardData.data[0];\nconst devotioCustomerId = card.customerId || '';\n\n// Código de producto de envío en InterFuerza — completar cuando el cliente confirme\nconst SHIPPING_CODE = ''; // ej: 'PS_ENVIO' o 'SHIP001'\n\n// Base: SubTotal (sin ITBMS). Si hay código de envío, se resta del SubTotal.\nconst lines = Array.isArray(inv.Lines) ? inv.Lines : [];\nlet amount;\nif (SHIPPING_CODE && lines.length > 0) {\n  const shippingTotal = lines\n    .filter(l => l.Codigo === SHIPPING_CODE)\n    .reduce((sum, l) => sum + parseFloat(l.Total || 0), 0);\n  amount = parseFloat((parseFloat(inv.SubTotal || 0) - shippingTotal).toFixed(2));\n} else {\n  amount = parseFloat(inv.SubTotal || 0);\n}\n\nconst pct = parseFloat($('Calcular Rango de Fechas').first().json.cashbackPct || '2');\nconst cashbackAmount = parseFloat((amount * pct / 100).toFixed(2));\n\nreturn [{ json: {\n  invoiceId: String(inv.id || inv.Id || ''),\n  amount,\n  cashbackAmount,\n  cashbackPct: pct,\n  branch: inv.Bodega || inv.bodega || '',\n  txDate: inv.Date || inv.date || new Date().toISOString(),\n  customerName: inv._customerName || '',\n  customerPhone: inv._phone || '',\n  customerEmail: inv._email || '',\n  devotioCustomerId,\n  cardId: card.id\n} }];"
      },
