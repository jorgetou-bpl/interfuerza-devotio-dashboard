      "id": "node-get-customer",
      "name": "Obtener Cliente InterFuerza",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        200
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const inv = $input.item.json;\n\nlet customer = {};\ntry {\n  const parsed = typeof inv.data === 'string' ? JSON.parse(inv.data) : (inv.data || {});\n  customer = parsed.customer || {};\n} catch(e) {}\n\nlet rawPhone = String(customer.Telefono_1 || customer.Cellular || '').replace(/\\D/g, '');\nlet phone = '';\nif (rawPhone.length === 8) {\n  phone = '507' + rawPhone;\n} else if (rawPhone.startsWith('507') && rawPhone.length === 11) {\n  phone = rawPhone;\n} else if (rawPhone.length > 0) {\n  phone = rawPhone;\n}\n\nconst email = String(customer.Email || '').trim();\n\nreturn { json: {\n  ...inv,\n  data: undefined,\n  _phone: phone,\n  _email: email,\n  _customerName: customer.Nombre || inv.Nombre || inv.Cliente || '',\n  _clienteId: inv.Cliente || inv.cliente || '',\n  _searchQuery: phone || email\n}};"
      },
