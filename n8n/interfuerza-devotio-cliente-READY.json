      "id": "node-get-processed",
      "name": "IDs Ya Procesados (Dedup)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Con fullResponse:true siempre recibimos 1 item aunque Supabase devuelva []\nconst supabaseResp = $input.first().json;\nconst rows = Array.isArray(supabaseResp.body) ? supabaseResp.body\n           : Array.isArray(supabaseResp) ? supabaseResp\n           : [];\nconst processedIds = new Set(rows.map(r => String(r.invoice_id)));\n\nconst fromDate = $('Calcular Rango de Fechas').first().json.fromDate || '2000-01-01';\n\nconst allInvoices = $('Preparar Dedup').first().json.invoices || [];\nconst newInvoices = allInvoices.filter(inv => {\n  const id = String(inv.id || inv.Id || inv.invoice_id || '');\n  if (!id || processedIds.has(id)) return false;\n  const type = String(inv.Type || '').toUpperCase();\n  if (type === 'INIT-BALANCE') return false;\n  if (String(inv.Date || '') < fromDate) return false;\n  return true;\n});\nreturn newInvoices.map(inv => ({ json: inv }));"
      },
